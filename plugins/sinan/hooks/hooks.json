{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks_src/session-context.js\"",
            "timeout": 10,
            "statusMessage": "Capturing Sinan session context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks_src/prompt-router.js\"",
            "timeout": 5,
            "statusMessage": "Routing prompt with Sinan"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks_src/bash-guard.js\"",
            "timeout": 3,
            "statusMessage": "Checking Bash command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks_src/stop-handoff.js\"",
            "timeout": 10,
            "statusMessage": "Preparing Sinan handoff"
          }
        ]
      }
    ]
  }
}
