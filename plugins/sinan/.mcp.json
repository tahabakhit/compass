{
  "mcpServers": {
    "sinan-state": {
      "command": "sh",
      "args": [
        "-lc",
        "exec node \"${PLUGIN_ROOT}/mcp-servers/sinan-state/index.js\""
      ],
      "env": {
        "SINAN_MCP_SERVER": "sinan-state"
      },
      "_codex": {
        "startup_timeout_sec": 10,
        "tool_timeout_sec": 30,
        "required": false,
        "instructions": "Use sinan_status to orient on campaign, fleet, telemetry, and artifact state before invoking Sinan workflows."
      }
    }
  }
}
