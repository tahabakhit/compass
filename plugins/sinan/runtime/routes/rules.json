{
  "schemaVersion": 1,
  "rules": [
    {
      "id": "micro-command-output",
      "priority": 100,
      "match": {
        "anyPromptIncludes": [
          "run `date`",
          "show git status",
          "what is in `package.json`"
        ]
      },
      "route": {
        "taskSize": "micro",
        "intent": "research",
        "workflow": null,
        "nativeMode": "none",
        "skills": [],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [],
        "budget": "small",
        "reason": "Simple command output."
      }
    },
    {
      "id": "micro-rewrite-translate",
      "priority": 100,
      "match": {
        "anyPromptIncludes": [
          "summarize this paragraph",
          "translate this",
          "make this sentence clearer",
          "what does this file do"
        ]
      },
      "route": {
        "taskSize": "micro",
        "intent": "research",
        "workflow": null,
        "nativeMode": "none",
        "skills": [],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [],
        "budget": "small",
        "reason": "Simple read or language task; no Sinan overhead."
      }
    },
    {
      "id": "implement-feature",
      "priority": 80,
      "match": {
        "anyPromptIncludes": [
          "add oauth login",
          "add feature",
          "implement",
          "build"
        ],
        "intentHints": [
          "implement"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "implement",
        "workflow": "implement",
        "nativeMode": "codex-plan",
        "skills": [
          "tdd"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Risky multi-file implementation needs plan and tests."
      }
    },
    {
      "id": "adversarial-review",
      "priority": 87,
      "match": {
        "anyPromptIncludes": [
          "adversarial review",
          "red-team review",
          "challenge review",
          "thermo review",
          "second opinion review",
          "pressure-test this diff",
          "audit this pr",
          "audit this diff",
          "review this pr",
          "code review"
        ],
        "intentHints": [
          "review"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "review",
        "workflow": "review",
        "nativeMode": "codex-plan",
        "skills": [
          "review"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Adversarial review should use native review when available, with Sinan review as fallback."
      }
    },
    {
      "id": "change-verification",
      "priority": 88,
      "match": {
        "anyPromptIncludes": [
          "verify this change",
          "verify the change",
          "verify my change",
          "verify this diff",
          "verify the diff",
          "check this change",
          "check this diff",
          "validate this change",
          "validate this diff",
          "verified change"
        ],
        "anyPromptMatches": [
          "(^|\\b(can you|could you|please|help me)\\s+)(verify|validate|check)\\b.{0,80}\\b(implementation|fix|change|diff|build|pr|pull request)\\b",
          "(^|\\b(can you|could you|please|help me)\\s+)?(verify|validate|check)\\s+this\\b.{0,80}\\b(commit|merge|release|diff|change|implementation|fix|build|pr|pull request)\\b",
          "(^|\\b(can you|could you|please|help me)\\s+)?(verify|validate|check)\\s+(this|the|my|our|their)\\s+(pr|pull request)\\b",
          "(^|\\b(can you|could you|please|help me)\\s+)?(verify|validate|check)\\s+((this|the|my|our|their)\\s+)?patch\\b([.!?]?$|\\s+(before|for|against|diff|change|implementation|fix|build|commit|merge|release)\\b)",
          "(^|\\b(can you|could you|please|help me)\\s+)?(verify|validate|check)\\s+((this|the|my|our|their)\\s+)?work\\b(?!\\s+(calendar|schedule|notes?)).{0,80}\\b(commit|merge|release|diff|change|implementation|fix|build)\\b",
          "(^|\\b(can you|could you|please|help me)\\s+)?(verify|validate|check)\\s+(this|the|my|our|their)\\s+work[.!?]?$",
          "(^|\\b(can you|could you|please|help me)\\s+)?(verify|validate|check)\\s+work[.!?]?$",
          "(^|\\b(can you|could you|please|help me)\\s+)(verify|validate)\\b.{0,80}\\b(the\\s+)?architecture[.!?]?$",
          "^(change|diff|implementation|fix|work)\\s+verification\\b",
          "^verification(\\s+(for|of)\\s+(this\\s+)?(change|diff|implementation|fix|work))?[.!?]?$"
        ],
        "intentHints": [
          "review"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "review",
        "workflow": "review",
        "nativeMode": "codex-plan",
        "skills": [
          "review"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Change verification should inspect the diff, run relevant checks, and report evidence."
      }
    },
    {
      "id": "bootstrap",
      "priority": 90,
      "match": {
        "anyPromptIncludes": [
          "bootstrap",
          "bootstrap this repo",
          "start this repo",
          "new repo",
          "empty repo",
          "resume from handoff",
          "previous handoff",
          "continuation notes"
        ],
        "intentHints": [
          "setup"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "bootstrap",
        "nativeMode": "codex-plan",
        "skills": [
          "bootstrap"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Bootstrap should inspect repo state and handoffs before choosing startup steps."
      }
    },
    {
      "id": "pre-implementation-architecture",
      "priority": 86,
      "match": {
        "anyPromptIncludes": [
          "architecture before implementation",
          "plan the architecture",
          "choose the architecture",
          "system shape",
          "module boundaries",
          "data shape"
        ],
        "intentHints": [
          "architecture"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "architecture",
        "workflow": "architecture-sweep",
        "nativeMode": "codex-plan",
        "skills": [
          "zoom-out",
          "architecture"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Architecture should choose boundaries before starter or implementation work."
      }
    },
    {
      "id": "brainstorm-idea",
      "priority": 85,
      "match": {
        "anyPromptIncludes": [
          "brainstorm",
          "think through",
          "shape this idea",
          "product direction",
          "acceptance criteria"
        ],
        "intentHints": [
          "clarify"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "clarify",
        "workflow": "clarify",
        "nativeMode": "codex-plan",
        "skills": [
          "brainstorm"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Ambiguous work should be shaped before decisions or implementation."
      }
    },
    {
      "id": "prototype-exploration",
      "priority": 85,
      "match": {
        "anyPromptIncludes": [
          "prototype the feature idea",
          "prototype this feature",
          "prototype the feature",
          "prototype this idea",
          "prototype the idea",
          "explore this feature",
          "explore the feature idea"
        ],
        "anyPromptMatches": [
          "(^|\\b(can you|could you|please|help me|let's|lets|let us)\\s+)(prototype|prototyping|sketch|sketching|explore|exploring)\\b.{0,80}\\b(options?|approach(?:es)?|ideas?|features?|solutions?)\\b"
        ],
        "intentHints": [
          "clarify"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "clarify",
        "workflow": "clarify",
        "nativeMode": "codex-plan",
        "skills": [
          "brainstorm"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Prototype language should explore the idea before choosing starter files or implementation."
      }
    },
    {
      "id": "slice-planning",
      "priority": 85,
      "match": {
        "anyPromptIncludes": [
          "slice plan",
          "slice-plan",
          "vertical slice plan",
          "plan the slice",
          "smallest slice",
          "first vertical slice"
        ],
        "anyPromptMatches": [
          "(^|\\b(can you|could you|please|help me|let's|lets)\\s+)(break|split|divide|slice)\\b.{0,80}\\bvertical slices?\\b",
          "(^|\\b(can you|could you|please|help me|let's|lets)\\s+)(break|split|divide|slice)\\b(?!.*\\b(from|out of)\\s+(the\\s+)?(path|list)\\b)(?=.{0,80}\\b(work|feature|task|implementation|release|project|epic|modules?)\\b).{0,80}\\b(slices?|slice plan)\\b",
          "(^|\\b(can you|could you|please|help me|let's|lets)\\s+)(break|split)\\b.{0,80}\\bmodules?[.!?]?$",
          "(^|\\b(can you|could you|please|help me|let's|lets)\\s+)(break|split)\\b.{0,80}\\bmodules?\\s+list[.!?]?$",
          "(^|\\b(can you|could you|please|help me|let's|lets)\\s+)slice\\b(?!.*\\b(from|out of)\\s+(the\\s+)?(path|list)\\b)(?!.*\\bby\\s+(path|name|path name)\\b).{0,80}\\bmodules?\\s+list[.!?]?$",
          "(^|\\b(can you|could you|please|help me|let's|lets)\\s+)slice\\b(?!.*\\b(from|out of)\\s+(the\\s+)?(path|list)\\b)(?!.*\\bby\\s+(path|name|path name)\\b).{0,80}\\bmodules?\\b(?!\\s+(name|names|path|paths|list)\\b)",
          "^(vertical[- ]slice|slice)\\s+planning\\s+(for|this|the|our|my)\\b"
        ],
        "intentHints": [
          "architecture"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "architecture",
        "workflow": "architecture-sweep",
        "nativeMode": "codex-plan",
        "skills": [
          "zoom-out",
          "architecture"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Slice planning is planning and architecture vocabulary, not a separate command users must remember."
      }
    },
    {
      "id": "decision-capture",
      "priority": 84,
      "match": {
        "anyPromptIncludes": [
          "decision capture",
          "capture decisions",
          "glossary.md",
          "write an adr",
          "architecture decision"
        ],
        "intentHints": [
          "clarify"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "clarify",
        "workflow": "clarify",
        "nativeMode": "codex-plan",
        "skills": [
          "decision-capture"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Durable project memory should be confirmed before writing."
      }
    },
    {
      "id": "doctor-readiness",
      "priority": 84,
      "match": {
        "anyPromptIncludes": [
          "run doctor",
          "doctor",
          "doctor this repo",
          "doctor on this repo",
          "repo doctor",
          "readiness check"
        ],
        "intentHints": [
          "setup"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "scaffold",
        "nativeMode": "codex-plan",
        "skills": [
          "scaffold"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Doctor/readiness checks should enforce scaffold and bootstrap signals without adding a new skill."
