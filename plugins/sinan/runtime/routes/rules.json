    {
      "id": "starter",
      "priority": 82,
      "match": {
        "anyPromptIncludes": [
          "starter",
          "app starter",
          "generate starter",
          "initial app files",
          "framework shell",
          "application shell"
        ],
        "intentHints": [
          "setup",
          "implement"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "starter",
        "nativeMode": "codex-plan",
        "skills": [
          "starter"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Starter generation should follow confirmed product and architecture decisions."
      }
