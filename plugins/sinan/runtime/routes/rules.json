        "reason": "Knowledge capture should draft or route to Zhi when available."
      }
    },
    {
      "id": "broad-research-audit",
      "priority": 60,
      "match": {
        "anyPromptIncludes": [
          "research audit",
          "audit this orchestration plugin",
          "audit this plugin",
          "audit this system",
          "audit this project",
          "design v2",
          "research",
          "compare"
        ],
        "intentHints": [
          "research"
        ]
      },
      "route": {
        "taskSize": "workflow",
        "intent": "research",
        "workflow": "research-audit",
        "nativeMode": "codex-plan",
        "skills": [
          "zoom-out"
        ],
        "agents": {
          "count": 3,
          "roles": [
            "research",
            "review",
            "compatibility"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "large",
        "reason": "Broad source-backed work earns workflow and bounded lanes."
      }
    }
  ]
}
