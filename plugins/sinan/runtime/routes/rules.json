{
  "schemaVersion": 1,
  "rules": [
    {
      "id": "micro-command-output",
      "priority": 100,
      "match": {
        "anyPromptIncludes": [
          "run `date`",
          "show git status",
          "what is in `package.json`"
        ]
      },
      "route": {
        "taskSize": "micro",
        "intent": "research",
        "workflow": null,
        "nativeMode": "none",
        "skills": [],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [],
        "budget": "small",
        "reason": "Simple command output."
      }
    },
    {
      "id": "micro-rewrite-translate",
      "priority": 100,
      "match": {
        "anyPromptIncludes": [
          "summarize this paragraph",
          "translate this",
          "make this sentence clearer",
          "what does this file do"
        ]
      },
      "route": {
        "taskSize": "micro",
        "intent": "research",
        "workflow": null,
        "nativeMode": "none",
        "skills": [],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [],
        "budget": "small",
        "reason": "Simple read or language task; no Sinan overhead."
      }
    },
    {
      "id": "implement-feature",
      "priority": 80,
      "match": {
        "anyPromptIncludes": [
          "add oauth login",
          "add feature",
          "implement",
          "build"
        ],
        "intentHints": [
          "implement"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "implement",
        "workflow": "implement",
        "nativeMode": "codex-plan",
        "skills": [
          "tdd"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Risky multi-file implementation needs plan and tests."
      }
    },
    {
      "id": "adversarial-review",
      "priority": 87,
      "match": {
        "anyPromptIncludes": [
          "adversarial review",
          "red-team review",
          "challenge review",
          "second opinion review",
          "pressure-test this diff"
        ],
        "intentHints": [
          "review"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "review",
        "workflow": "review",
        "nativeMode": "codex-plan",
        "skills": [
          "review"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Adversarial review should use native review when available, with Sinan review as fallback."
      }
    },
    {
      "id": "bootstrap",
      "priority": 90,
      "match": {
        "anyPromptIncludes": [
          "bootstrap",
          "bootstrap this repo",
          "start this repo",
          "new repo",
          "empty repo",
          "resume from handoff",
          "previous handoff",
          "continuation notes"
        ],
        "intentHints": [
          "setup"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "bootstrap",
        "nativeMode": "codex-plan",
        "skills": [
          "bootstrap"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Bootstrap should inspect repo state and handoffs before choosing startup steps."
      }
    },
    {
      "id": "pre-implementation-architecture",
      "priority": 86,
      "match": {
        "anyPromptIncludes": [
          "architecture before implementation",
          "plan the architecture",
          "choose the architecture",
          "system shape",
          "module boundaries",
          "data shape"
        ],
        "intentHints": [
          "architecture"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "architecture",
        "workflow": "architecture-sweep",
        "nativeMode": "codex-plan",
        "skills": [
          "zoom-out",
          "architecture"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "review"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Architecture should choose boundaries before starter or implementation work."
      }
    },
    {
      "id": "brainstorm-idea",
      "priority": 85,
      "match": {
        "anyPromptIncludes": [
          "brainstorm",
          "think through",
          "shape this idea",
          "product direction",
          "acceptance criteria"
        ],
        "intentHints": [
          "clarify"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "clarify",
        "workflow": "clarify",
        "nativeMode": "codex-plan",
        "skills": [
          "brainstorm"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Ambiguous work should be shaped before decisions or implementation."
      }
    },
    {
      "id": "decision-capture",
      "priority": 84,
      "match": {
        "anyPromptIncludes": [
          "decision capture",
          "capture decisions",
          "glossary.md",
          "write an adr",
          "architecture decision"
        ],
        "intentHints": [
          "clarify"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "clarify",
        "workflow": "clarify",
        "nativeMode": "codex-plan",
        "skills": [
          "decision-capture"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Durable project memory should be confirmed before writing."
      }
    },
    {
      "id": "scaffold",
      "priority": 83,
      "match": {
        "anyPromptIncludes": [
          "agent scaffold",
          "scaffold instructions",
          "set up instructions",
          "agents.md",
          "claude.md",
          "github labels",
          "github workflows"
        ],
        "intentHints": [
          "setup"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "scaffold",
        "nativeMode": "codex-plan",
        "skills": [
          "scaffold"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "small",
        "reason": "Agent scaffolding should inspect and propose before writing."
      }
    },
    {
      "id": "starter",
      "priority": 82,
      "match": {
        "anyPromptIncludes": [
          "starter",
          "app starter",
          "generate starter",
          "initial app files",
          "framework shell",
          "application shell"
        ],
        "intentHints": [
          "setup",
          "implement"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "starter",
        "nativeMode": "codex-plan",
        "skills": [
          "starter"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Starter generation should follow confirmed product and architecture decisions."
      }
    },
    {
      "id": "cleanup-delete",
      "priority": 80,
      "match": {
        "anyPromptIncludes": [
          "delete unused hook scripts",
          "cleanup",
          "prune",
          "reorganize"
        ],
        "intentHints": [
          "cleanup"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "cleanup",
        "workflow": "cleanup",
        "nativeMode": "codex-plan",
        "skills": [
          "architecture"
        ],
        "agents": {
          "count": 1,
          "roles": [
            "verification"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Deletion needs inventory, replacement coverage, and review."
      }
    },
    {
      "id": "debug-failing-test",
      "priority": 70,
      "match": {
        "anyPromptIncludes": [
          "failing test",
          "broken",
          "regression"
        ],
        "intentHints": [
          "debug"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "debug",
        "workflow": "debug",
        "nativeMode": "codex-plan",
        "skills": [
          "diagnose"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "medium",
        "reason": "Debugging benefits from reproduce-minimize-fix verification."
      }
    },
    {
      "id": "handoff",
      "priority": 65,
      "match": {
        "anyPromptIncludes": [
          "handoff",
          "continuation summary",
          "compact handoff"
        ],
        "intentHints": [
          "handoff"
        ]
      },
      "route": {
        "taskSize": "light",
        "intent": "handoff",
        "workflow": null,
        "nativeMode": "none",
        "skills": [
          "handoff"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [],
        "budget": "small",
        "reason": "Focused continuation summary; no workflow needed."
      }
    },
    {
      "id": "broad-research-audit",
      "priority": 60,
      "match": {
        "anyPromptIncludes": [
          "audit",
          "research",
          "compare"
        ],
        "intentHints": [
          "research"
        ]
      },
      "route": {
        "taskSize": "workflow",
        "intent": "research",
        "workflow": "research-audit",
        "nativeMode": "codex-plan",
        "skills": [
          "zoom-out"
        ],
        "agents": {
          "count": 3,
          "roles": [
            "research",
            "review",
            "compatibility"
          ]
        },
        "hooks": [
          "bash-guard"
        ],
        "budget": "large",
        "reason": "Broad source-backed work earns workflow and bounded lanes."
      }
    }
  ]
}
