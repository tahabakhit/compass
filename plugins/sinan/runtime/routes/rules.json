    },
    {
      "id": "scaffold",
      "priority": 83,
      "match": {
        "anyPromptIncludes": [
          "agent scaffold",
          "scaffold instructions",
          "set up instructions",
          "set this up",
          "set this project up",
          "need to set this up",
          "can you set this up",
          "agents.md",
          "claude.md",
          "github labels",
          "github workflows"
        ],
        "intentHints": [
          "setup"
        ]
      },
      "route": {
        "taskSize": "full",
        "intent": "setup",
        "workflow": "scaffold",
        "nativeMode": "codex-plan",
        "skills": [
          "scaffold"
        ],
        "agents": {
          "count": 0,
          "roles": []
        },
        "hooks": [
          "bash-guard"
        ],
