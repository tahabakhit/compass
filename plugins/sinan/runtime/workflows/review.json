{
  "id": "review",
  "description": "Produce high-confidence review findings with evidence.",
  "triggers": [
    "review",
    "audit diff",
    "pr feedback",
    "adversarial review",
    "red-team review",
    "challenge review"
  ],
  "mode": {
    "default": "medium"
  },
  "native": {
    "codex": "subagents_allowed",
    "claude": "plan_mode_optional"
  },
  "phases": [
    {
      "id": "inspect-diff"
    },
    {
      "id": "trace-behavior"
    },
    {
      "id": "native-adversarial-review",
      "when": "Claude Code has codex@openai-codex and the user requests adversarial, red-team, or second-opinion review."
    },
    {
      "id": "identify-risks"
    },
    {
      "id": "verify-findings"
    },
    {
      "id": "report"
    }
  ],
  "gates": [
    "findings-evidenced",
    "adversarial-output-handled",
    "no-speculation"
  ],
  "budget": {
    "default_agents": 1,
    "max_agents": 3,
    "max_minutes": 45
  },
  "resume": {
    "state_dir": ".workflow-state/runs",
    "persist": "summaries_only"
  }
}
