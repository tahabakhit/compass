{
  "id": "scaffold",
  "description": "Inspect and propose agent instruction scaffolding.",
  "triggers": [
    "setup workspace",
    "scaffold",
    "scaffold instructions",
    "agent scaffold",
    "doctor instructions"
  ],
  "mode": {
    "default": "small"
  },
  "native": {
    "codex": "plan_mode_optional",
    "claude": "plan_mode_optional"
  },
  "phases": [
    {
      "id": "inspect-surfaces"
    },
    {
      "id": "detect-project"
    },
    {
      "id": "inspect-github-surfaces"
    },
    {
      "id": "propose-diff"
    },
    {
      "id": "wait-for-confirmation"
    },
    {
      "id": "write-if-approved"
    },
    {
      "id": "verify-generated-surfaces"
    }
  ],
  "gates": [
    "proposal-shown-before-write",
    "manual-text-preserved",
    "generated-markers-present",
    "github-guidance-explicit"
  ],
  "budget": {
    "default_agents": 0,
    "max_agents": 1,
    "max_minutes": 30
  },
  "resume": {
    "state_dir": ".workflow-state/runs",
    "persist": "summaries_only"
  }
}
