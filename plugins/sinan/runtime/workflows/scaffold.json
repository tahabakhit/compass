{
  "id": "scaffold",
  "description": "Audit, propose, and optionally write repo-local agent policy scaffolding.",
  "triggers": [
    "setup workspace",
    "scaffold",
    "scaffold instructions",
    "agent scaffold",
    "doctor instructions"
  ],
  "mode": {
    "default": "small"
  },
  "native": {
    "codex": "plan_mode_optional",
    "claude": "plan_mode_optional"
  },
  "phases": [
    {
      "id": "inspect-surfaces"
    },
    {
      "id": "detect-repo-type"
    },
    {
      "id": "audit-layout"
    },
    {
      "id": "inspect-github-surfaces"
    },
    {
      "id": "propose-diff"
    },
    {
      "id": "wait-for-confirmation"
    },
    {
      "id": "write-if-approved"
    },
    {
      "id": "verify-generated-surfaces"
    },
    {
      "id": "review"
    }
  ],
  "gates": [
    "advisory-audit-default",
    "proposal-shown-before-write",
    "manual-text-preserved",
    "generated-surfaces-verified",
    "generated-markers-present",
    "agents-policy-bundle-present",
    "github-guidance-explicit",
    "diff-reviewed"
  ],
  "budget": {
    "default_agents": 0,
    "max_agents": 1,
    "max_minutes": 30
  },
  "resume": {
    "state_dir": ".workflow-state/runs",
    "persist": "summaries_only"
  }
}
